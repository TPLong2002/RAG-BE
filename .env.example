# Server
PORT=3001

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_password
NEO4J_DATABASE=neo4j

# MSSQL (for schema import feature)
MSSQL_SERVER=localhost
MSSQL_PORT=1433
MSSQL_DATABASE=YourDatabase
MSSQL_USER=sa
MSSQL_PASSWORD=YourPassword
MSSQL_ENCRYPT=false
MSSQL_TRUST_CERT=true

# AI APIs
OPENAI_API_KEY=your_openai_key
GOOGLE_API_KEY=your_google_key
AISTUDIO_API_KEY=sk-placeholder
AISTUDIO_BASE_URL=http://localhost:2048/v1

# Embeddings
DEFAULT_EMBEDDING_PROVIDER=openai
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Search
SEARCH_TOP_K=5
SEARCH_VECTOR_WEIGHT=0.7
SEARCH_FULLTEXT_WEIGHT=0.3

# Graph
GRAPH_SIMILARITY_THRESHOLD=0.8
GRAPH_SIMILARITY_TOP_K=5
GRAPH_MIN_RELATED_CONNECTIONS=2
